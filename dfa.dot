digraph DFA {
  rankdir=LR;
  node [fontname="Courier" fontsize=12];
  edge [fontname="Courier" fontsize=11];
  __start [shape=plaintext label=""];
  __start -> q0;
  q1 [shape=doublecircle];
  q0 [shape=circle];
  q1 -> q1 [label="b"];
  q1 -> q0 [label="a"];
  q0 -> q1 [label="b"];
  q0 -> q0 [label="a"];
}
